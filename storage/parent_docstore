eliability_score": 0.9}, "temporal": {"publication_date": "2008", "last_updated": "August 2014", "validity_period": "2008", "version": null}, "classification": {"education_level": ["tertiary"], "content_type": "handbook", "subject_areas": ["Computer Science", "Engineering", "Mathematics", "Economics"], "geographic_scope": "institutional", "institution_types": ["university"]}, "processing": {"extraction_method": "manual", "quality_score": 0.9, "human_verified": false, "last_reviewed": null, "last_modified": null}, "linguistic": {"primary_language": "english", "secondary_languages": [], "terminology_complexity": "intermediate"}, "search_optimization": {"keywords": ["Obafemi Awolowo University", "Ile-Ife", "Computer Science", "Engineering", "Handbook", "Students", "Undergraduate", "Postgraduate", "Degree Program", "Examination Regulations"], "synonyms": [], "common_queries": ["What are the admission requirements?", "What courses are offered?", "What are the examination rules?", "Who are the departmental staff?", "What are the university facilities?"]}}, "document_id": "9af9d4ac-bfd1-420d-b3cf-de2fa40f2758"}, "hash": "e864d00a829b4963bee43df558eb37c7b824b8f0953753577182ebe4bc5163bd", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "3.3 Course  s   in Computer Science   and Engineering  \nThree undergraduate programmes are offered, each leading to the degree of B.Sc.\n(a) Honours degree in Computer Engineering\n(b) Honours degree in Computer Science/Mathematics\n(c) Combined Honours degree in Computer Science/Economics\nA core of Computer Science courses which provide a sound knowledge of hardware, software and  \napplications is in general, common to all programmes.  Student pursuing the  Computer Science  \nprogrammes also acquire the in-depth knowledge of mathematics skills require for the formulation  \nand solution of problems in Science and Applied Sciences with Computing Skills .  Students offering \nthe  Economics  programme  receive  training  in  micro  and  macro  economics  principles,  business \nmanagement skills ,  required  for  the  sound  application  of  computer  to  the  data  processing \nrequirements  of  banks,  insurance,  commerce,  government,  etc.   Students  attending  the  honours \ndegree course in Computer Engineering will receive intensive instruction across the whole spectrum  \nof Computer Science, and exposure to relevant areas of Mathematics and Electronics. In addition,  \nthey will be able to choose an area of specialization such as Advanced Computer Engineering or  \nAdvanced Software Application .  During the long vacations following Parts III and IV , the students  \nare sent on Industrial Attachment and during their final year they undertake an individual project on a  \ntopic of their choice.  Graduates from th ese courses can expect to find employment as specialists in  \nComputer Engineering , Hardware Applications, Scientific or Commercial Programming, Computer  \nSoftware etc.  They will have received sufficient specialist training for them to be immediately useful  \nin  government,  history  or  research  establishments,  without  the  need  for  further  re-orientation. \nGraduate from this course can expect to find employment as specialists in Computer Engineering  \nHardware Applications, Scientifics or Commercial Programming, Computer Software etc.\nStudents who obtained the Combined Honours degree in Computer Science /Economics or Copmuter \nScience would have received a thorough background in Computer Science including Numerical  \nTechniques,  Software  and  systems  analysis  as  well  an  having  acquired  the  Mathematics  skills \nnecessary to apply those disciplines in scientific applications.   It is anticipated that such students will  \nmeet Nigeria\u2019s need for scientific programmes and find employment in Engineering, Production  \nIndustries including Petrol-chemicals, Research establishments.  Government Statistics Services and  \nUniversities.  \nAs  earlier  stated  the Department  runs  three  programmes  namely,  Computer  Science/Economics, \nComputer Science, and Computer Engineering.", "mimetype": "text/plain", "start_char_idx": 14317, "end_char_idx": 17165, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "987d1371-e8e2-4f0f-ad73-ed6dd0a18624": {"__data__": {"id_": "987d1371-e8e2-4f0f-ad73-ed6dd0a18624", "embedding": null, "metadata": {"page_label": "1", "file_name": "undergradute_handbook.pdf", "file_path": "data/undergradute_handbook.pdf", "file_type": "application/pdf", "file_size": 423047, "creation_date": "2025-07-23", "last_modified_date": "2025-07-23", "source_type": "file", "page_count": 31, "edubot_metadata": {"document_id": "9af9d4ac-bfd1-420d-b3cf-de2fa40f2758", "date_uploaded": "2025-07-31T01:10:20.972861", "title": "2008 Handbook", "summary": "This handbook provides information for Computer Science and Engineering students at Obafemi Awolowo University, Ile-Ife. It covers departmental staff, university history, facilities, examination regulations, the degree program, and procedures for academic matters.  The handbook aims to guide students through their studies and advises them to consult their academic advisors for major decisions.", "source": {"organization": "Obafemi Awolowo University", "url": null, "authority_tier": 3, "reliability_score": 0.9}, "temporal": {"publication_date": "2008", "last_updated": "August 2014", "validity_period": "2008", "version": null}, "classification": {"education_level": ["tertiary"], "content_type": "handbook", "subject_areas": ["Computer Science", "Engineering", "Mathematics", "Economics"], "geographic_scope": "institutional", "institution_types": ["university"]}, "processing": {"extraction_method": "manual", "quality_score": 0.9, "human_verified": false, "last_reviewed": null, "last_modified": null}, "linguistic": {"primary_language": 